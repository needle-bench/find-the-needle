---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'An open benchmark where developers submit real bugs as frozen Docker snapshots and AI agents find the needle.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={`https://needle-bench.cc${currentPath}`}>
  <meta name="twitter:card" content="summary">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script defer data-domain="needle-bench.cc" src="https://plausible.io/js/script.outbound-links.js"></script>
</head>
<body>
  <nav class="topnav">
    <a href="/" class="brand">needle-bench <span class="brand-sub">by ostk</span></a>
    <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
    <a href="/leaderboard/" class:list={[{ active: currentPath.startsWith('/leaderboard') }]}>Leaderboard</a>
    <a href="https://ostk.ai/insights">Insights</a>
    <a href="/contribute/" class:list={[{ active: currentPath.startsWith('/contribute') }]}>Contribute</a>
    <span class="nav-sep">|</span> <a href="https://ostk.ai">ostk.ai</a>
    <a href="https://github.com/os-tack/find-the-needle">GitHub</a>
  </nav>

  <slot />

  <footer>
    Built with <a href="https://github.com/os-tack/find-the-needle">needle-bench</a>. Open source.<br>
    <a href="https://github.com/os-tack/find-the-needle">GitHub</a> &middot;
    <a href="https://github.com/os-tack/find-the-needle/blob/main/LICENSE">MIT License</a> &middot;
    All benchmarks are real bugs, anonymized.
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  .brand-sub {
    font-weight: 400;
    font-size: 0.7em;
    color: var(--text-muted);
    margin-left: 0.3em;
  }

  .nav-sep {
    color: var(--border);
    user-select: none;
  }
</style>
