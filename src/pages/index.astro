---
import Base from '../layouts/Base.astro';

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "needle-bench AI Coding Agent Benchmark",
  "description": "Open benchmark for AI coding agents. 34 models × 24 benchmarks × 3 arms. Deterministic scoring.",
  "url": "https://needle-bench.cc",
  "license": "https://opensource.org/licenses/MIT",
  "creator": {
    "@type": "Organization",
    "name": "os-tack",
    "url": "https://github.com/os-tack"
  },
  "distribution": {
    "@type": "DataDownload",
    "encodingFormat": "application/json",
    "contentUrl": "https://needle-bench.cc/experiment-scores.json"
  }
};
---

<!-- Index redirects to leaderboard content inline -->
<meta http-equiv="refresh" content="0; url=/leaderboard/" />
<Base title="needle-bench — find the needle" description="34 models. 3 arms. 1,511 runs. One prompt: find the needle." jsonLd={datasetSchema}>
  <main>
    <p>Redirecting to <a href="/leaderboard/">leaderboard</a>...</p>
  </main>
</Base>
