const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Kernel lift: what happens when the same model runs through a shared agent loop",
  "description": "How 31 AI coding models perform on real Docker bugs when swapped out of their native vendor CLI and into a shared ostk agent loop. Claude Opus goes from 58% to 100%. Non-agent models unlock from 0% to 90%+.",
  "datePublished": "2026-04-09",
  "author": {
    "@type": "Organization",
    "name": "needle-bench",
    "url": "https://needle-bench.cc/"
  },
