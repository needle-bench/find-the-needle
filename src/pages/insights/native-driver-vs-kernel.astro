const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Native driver vs kernel: does the CPU arm pay for itself?",
  "description": "The ostk CPU arm wires models straight into the agent loop through native API drivers, bypassing OpenRouter. For most tested models the delta is small. For one it's 57 percentage points.",
  "datePublished": "2026-04-09",
