---
import Base from '../layouts/Base.astro';
---

<Base title="needle-bench — find the needle" description="34 models. 3 arms. 1,511 runs. One prompt: find the needle.">
  <main>
    <div class="experiment-info">
      <p><strong>Three-arm experiment.</strong> 34 models &times; 24 benchmarks &times; 3 arms.</p>
      <p class="muted"><strong>Native</strong>: vendor CLI (Claude Code, Gemini CLI, etc). <strong>Kernel</strong>: ostk agent loop via OpenRouter. <strong>CPU</strong>: ostk with optimized native drivers. Same prompt, same tools. Click headers to sort.</p>
    </div>

    <div class="lb-container" id="lb-container">
      <table id="lb">
        <thead>
          <tr id="lb-head">
            <th class="col-model" data-key="model">Model</th>
            <th class="col-price" data-key="price">$/M</th>
            <th class="col-arm" data-key="nativePct" title="Native: vendor CLI, own API key">Native</th>
            <th class="col-arm" data-key="kernelPct" title="Kernel: ostk agent loop via OpenRouter">Kernel</th>
            <th class="col-arm" data-key="cpuPct" title="CPU: ostk with optimized native driver">CPU</th>
            <th class="col-delta" data-key="bestDelta" title="Best kernel lift over native">&Delta;</th>
            <th class="col-cost" data-key="bestCost" title="Total cost of best arm">Cost</th>
            <th class="col-num" data-key="bestTokens" title="Total tokens (best arm)">Tokens</th>
            <th class="col-num" data-key="bestTools" title="Tool invocations (best arm)">Tools</th>
            <th class="col-num" data-key="bestTurns" title="Agent turns (best arm)">Turns</th>
            <th class="col-num" data-key="bestWall" title="Wall clock (best arm)">Time</th>
          </tr>
        </thead>
        <tbody id="lb-body">
          <tr><td colspan="11" class="empty">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <div class="totals" id="totals"></div>

    <section class="results-summary">
      <h2>Results</h2>
      <p>The kernel doubles solve rate and cuts cost 83%. Same models, same tools, same prompt.</p>

      <div class="arm-comparison" id="arm-comparison"></div>

      <h3>Key findings</h3>
      <ul>
        <li><strong>Kernel lift</strong>: native 40% &rarr; kernel 82%. Average +42pp across 34 models.</li>
        <li><strong>Cost efficiency</strong>: optimized CPU driver achieves 82% solve at $15 total vs $87 for native CLIs.</li>
        <li><strong>Cheap models win</strong>: Haiku ($1/M) with kernel matches o3 ($2/M) at 59%. Gemini Flash ($0.30/M) hits 100% with CPU driver.</li>
        <li><strong>Driver matters</strong>: Devstral jumps 22% &rarr; 54% just by switching OpenRouter &rarr; native Mistral driver.</li>
        <li><strong>Tool use signal</strong>: kernel runs average 5&ndash;15 tool calls in 1 turn vs native CLIs needing 200+ turns for the same solve.</li>
      </ul>

      <h3>Methodology</h3>
      <ul>
        <li>24 Docker-containerized benchmarks with real bugs (easy, medium, hard).</li>
        <li>Deterministic test: <code>test.sh</code> exits 0 = fixed.</li>
        <li>Kernel arm routes all models through OpenRouter for fair comparison.</li>
        <li>CPU arm uses optimized native drivers (Anthropic prompt caching, Gemini, Mistral).</li>
        <li>Native arm uses each vendor&rsquo;s own CLI with their API key.</li>
        <li>System prompt: &ldquo;This is a benchmark. There is a hidden problem. Find the needle in the haystack.&rdquo;</li>
      </ul>
    </section>
  </main>
</Base>

<style is:global>
  main { max-width: none; padding: 1rem 2rem 2rem; }

  .experiment-info { font-size: 0.85rem; max-width: 800px; margin-bottom: 1rem; line-height: 1.5; }
  .experiment-info p { margin: 0 0 0.25rem; }

  .lb-container {
    overflow-x: auto; border: 1px solid var(--border); border-radius: 6px;
    background: var(--bg); -webkit-overflow-scrolling: touch;
  }

  #lb { border-collapse: separate; border-spacing: 0; min-width: 100%; font-size: 0.75rem; }
  #lb th {
    padding: 0.5rem 0.5rem; font-size: 0.65rem; letter-spacing: 0.04em;
    text-transform: uppercase; background: var(--surface); border-bottom: 2px solid var(--border);
    white-space: nowrap; cursor: pointer; user-select: none; text-align: right;
  }
  #lb th.sorted { color: #d4a054; }
  #lb th:first-child { text-align: left; position: sticky; left: 0; z-index: 3; }
  #lb th[title] { cursor: help; }

  .col-model { min-width: 160px; width: 160px; position: sticky; left: 0; z-index: 2; background: var(--surface); }
  .col-price { min-width: 50px; text-align: right; }
  .col-arm { min-width: 65px; text-align: center !important; }
  .col-delta { min-width: 55px; text-align: center !important; }
  .col-cost { min-width: 60px; }
  .col-num { min-width: 55px; }

  #lb td {
    padding: 0.35rem 0.5rem; border-bottom: 1px solid var(--border);
    font-family: var(--mono); font-size: 0.7rem; white-space: nowrap; text-align: right;
  }
  #lb td:first-child { text-align: left; position: sticky; left: 0; z-index: 2; background: var(--surface); }
  #lb tr:nth-child(even) td { background-color: rgba(255,255,255,0.02); }
  #lb tr:nth-child(even) td:first-child { background-color: color-mix(in srgb, var(--surface) 97%, white); }
  #lb tr:hover td { background: rgba(255,255,255,0.06); }
  #lb tr:hover td:first-child { background: color-mix(in srgb, var(--surface) 94%, white); }

  .model-name { font-weight: 600; font-size: 0.75rem; color: var(--text); }

  .solve-pct { font-weight: 700; }
  .pct-100 { color: #3fb950; }
  .pct-90  { color: #3fb950; }
  .pct-70  { color: #d29922; }
  .pct-50  { color: #db6d28; }
  .pct-30  { color: #f85149; }
  .pct-0   { color: #484f58; }
  .pct-na  { color: #484f58; font-weight: 400; }

  .delta-pos { color: #3fb950; font-weight: 600; }
  .delta-neg { color: #f85149; font-weight: 600; }
  .delta-zero { color: #484f58; }

  .totals { font-size: 0.8rem; margin: 0.75rem 0; color: var(--text-muted); font-family: var(--mono); }

  .arm-comparison {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;
    margin: 1rem 0; font-family: var(--mono); font-size: 0.8rem;
  }
  .arm-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
    padding: 0.75rem 1rem;
  }
  .arm-card h4 { margin: 0 0 0.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
  .arm-card .big { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
  .arm-card .detail { font-size: 0.7rem; color: var(--text-muted); }

  .results-summary { max-width: 800px; margin: 2rem auto; padding: 0 2rem; font-size: 0.9rem; line-height: 1.6; }
  .results-summary h2 { margin-top: 0; }
  .results-summary h3 { margin: 1.25rem 0 0.5rem; font-size: 1rem; }
  .results-summary ul { padding-left: 1.5rem; margin: 0.5rem 0; }
  .results-summary li { margin-bottom: 0.35rem; }

  @media (max-width: 768px) {
    .arm-comparison { grid-template-columns: 1fr; }
    main { padding: 0.5rem; }
    .col-model { width: 110px; min-width: 110px; }
  }
</style>

<script>
  interface ArmAgg { solved: number; total: number; cost: number; tokens: number; tools: number; turns: number; wall: number; }
  interface ModelData {
    model: string; model_normalized: string; benchmarks: number;
    native: ArmAgg; kernel: ArmAgg; cpu: ArmAgg;
    price_per_m_input?: number; price_per_m_output?: number;
  }

  function fmtN(n: number) { return n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(0)+'k' : String(n); }
  function fmtT(s: number) { return s >= 3600 ? (s/3600).toFixed(1)+'h' : s >= 60 ? (s/60).toFixed(0)+'m' : Math.round(s)+'s'; }
  function fmtUsd(n: number) { return n >= 1 ? '$'+n.toFixed(2) : n > 0 ? '$'+n.toFixed(3) : '-'; }
  function pctClass(pct: number) { return pct >= 100 ? 'pct-100' : pct >= 90 ? 'pct-90' : pct >= 70 ? 'pct-70' : pct >= 50 ? 'pct-50' : pct > 0 ? 'pct-30' : 'pct-0'; }

  function armPct(a: ArmAgg): number { return a.total > 0 ? a.solved / a.total * 100 : -1; }
  function armLabel(a: ArmAgg): string {
    if (a.total === 0) return '<span class="pct-na">-</span>';
    const pct = armPct(a);
    return `<span class="solve-pct ${pctClass(pct)}">${a.solved}/${a.total}</span>`;
  }

  function bestArm(m: ModelData): { arm: ArmAgg; name: string } {
    const arms: [ArmAgg, string][] = [[m.cpu, 'cpu'], [m.kernel, 'kernel'], [m.native, 'native']];
    let best: [ArmAgg, string] = arms[0];
    for (const [a, n] of arms) {
      if (a.total === 0) continue;
      const bPct = best[0].total > 0 ? best[0].solved / best[0].total : -1;
      const aPct = a.solved / a.total;
      if (aPct > bPct || (aPct === bPct && a.cost < best[0].cost && a.cost > 0)) {
        best = [a, n];
      }
    }
    return { arm: best[0], name: best[1] };
  }

  async function init() {
    const resp = await fetch('/experiment-scores.json');
    const data = await resp.json();
    const models: ModelData[] = data.models;

    // Compute derived fields
    const rows = models.map(m => {
      const nPct = armPct(m.native);
      const kPct = armPct(m.kernel);
      const cPct = armPct(m.cpu);
      const best = bestArm(m);
      const bestPct = best.arm.total > 0 ? best.arm.solved / best.arm.total * 100 : 0;
      const delta = nPct >= 0 ? Math.max(kPct, cPct) - nPct : (kPct >= 0 ? kPct : cPct);
      return {
        ...m,
        nativePct: nPct, kernelPct: kPct, cpuPct: cPct,
        bestDelta: delta,
        bestCost: best.arm.cost,
        bestTokens: best.arm.tokens,
        bestTools: best.arm.tools,
        bestTurns: best.arm.turns,
        bestWall: best.arm.wall,
        bestPct,
        price: m.price_per_m_input || 0,
      };
    });

    // Sort by best solve % desc, then cost asc
    let sortKey = 'bestPct';
    let sortDir = -1;
    const sort = () => rows.sort((a: any, b: any) => {
      const av = a[sortKey] ?? 0, bv = b[sortKey] ?? 0;
      return sortDir * (typeof av === 'string' ? av.localeCompare(bv) : av - bv);
    });

    const render = () => {
      sort();
      const tbody = document.getElementById('lb-body')!;
      tbody.innerHTML = rows.map(r => {
        const delta = r.bestDelta;
        const deltaHtml = delta > 0 ? `<span class="delta-pos">+${delta.toFixed(0)}</span>`
          : delta < 0 ? `<span class="delta-neg">${delta.toFixed(0)}</span>`
          : `<span class="delta-zero">0</span>`;
        return `<tr>
          <td class="col-model"><span class="model-name">${r.model_normalized}</span></td>
          <td class="col-price">${r.price > 0 ? '$'+r.price.toFixed(2) : '-'}</td>
          <td class="col-arm">${armLabel(r.native)}</td>
          <td class="col-arm">${armLabel(r.kernel)}</td>
          <td class="col-arm">${armLabel(r.cpu)}</td>
          <td class="col-delta">${deltaHtml}</td>
          <td class="col-cost">${fmtUsd(r.bestCost)}</td>
          <td class="col-num">${r.bestTokens > 0 ? fmtN(r.bestTokens) : '-'}</td>
          <td class="col-num">${r.bestTools > 0 ? r.bestTools : '-'}</td>
          <td class="col-num">${r.bestTurns > 0 ? r.bestTurns : '-'}</td>
          <td class="col-num">${r.bestWall > 0 ? fmtT(r.bestWall) : '-'}</td>
        </tr>`;
      }).join('');

      // Update headers
      document.querySelectorAll('#lb-head th').forEach(th => {
        th.classList.toggle('sorted', (th as HTMLElement).dataset.key === sortKey);
      });
    };

    // Header click sorting
    document.querySelectorAll('#lb-head th').forEach(th => {
      th.addEventListener('click', () => {
        const key = (th as HTMLElement).dataset.key;
        if (!key) return;
        if (sortKey === key) sortDir *= -1;
        else { sortKey = key; sortDir = key === 'model' ? 1 : -1; }
        render();
      });
    });

    render();

    // Totals
    const totalScores = rows.reduce((s, r) => s + r.native.total + r.kernel.total + r.cpu.total, 0);
    const totalSolved = rows.reduce((s, r) => s + r.native.solved + r.kernel.solved + r.cpu.solved, 0);
    const totalCost = rows.reduce((s, r) => s + r.native.cost + r.kernel.cost + r.cpu.cost, 0);
    document.getElementById('totals')!.textContent =
      `${rows.length} models \u00b7 ${totalScores.toLocaleString()} benchmarks \u00b7 ${totalSolved.toLocaleString()} solved \u00b7 $${totalCost.toFixed(2)} total spend`;

    // Arm comparison cards
    const armTotals = (key: 'native' | 'kernel' | 'cpu') => {
      const t = rows.reduce((a, r) => ({
        s: a.s + r[key].solved, t: a.t + r[key].total, c: a.c + r[key].cost
      }), { s: 0, t: 0, c: 0 });
      return t;
    };
    const cards = (['native', 'kernel', 'cpu'] as const).map(arm => {
      const labels: Record<string, string> = { native: 'Native (vendor CLI)', kernel: 'Kernel (OpenRouter)', cpu: 'Kernel-CPU (optimized)' };
      const t = armTotals(arm);
      const pct = t.t > 0 ? (t.s / t.t * 100).toFixed(0) : '0';
      return `<div class="arm-card">
        <h4>${labels[arm]}</h4>
        <div class="big ${pctClass(Number(pct))}">${pct}%</div>
        <div class="detail">${t.s}/${t.t} solved \u00b7 $${t.c.toFixed(2)}</div>
      </div>`;
    });
    document.getElementById('arm-comparison')!.innerHTML = cards.join('');
  }

  init();
</script>
</Base>
