+import unicodedata


 # Matches any HTML tag (opening, closing, self-closing)
@@ -33,6 +34,10 @@ def sanitize_username(username: str) -> str:
     # Step 2: Strip any residual HTML tags (belt-and-suspenders)
     cleaned = _HTML_TAG_RE.sub("", cleaned)

+    # Step 2.5: Strip Unicode control characters (Cc, Cf, Co, Cs)
+    # This blocks BIDI override chars (U+202E, U+202D, etc.) and other
+    # invisible control characters that could be used for spoofing.
+    cleaned = "".join(ch for ch in cleaned if unicodedata.category(ch)[0] not in ("C",))
+
     # Step 3: Reject script injection patterns
     if _SCRIPT_RE.search(cleaned):
         raise ValueError("Username contains disallowed script patterns")
