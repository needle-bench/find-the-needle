+
+// sortChainCerts reorders Certificate[1:] so that each certificate is
+// followed by its issuer. Certificate[0] (the leaf) is left in place.
+func sortChainCerts(cert *tls.Certificate) {
+	if len(cert.Certificate) <= 2 {
+		return
+	}
+
+	chain := cert.Certificate[1:]
+	parsed := make([]*x509.Certificate, len(chain))
+	for i, der := range chain {
+		c, err := x509.ParseCertificate(der)
+		if err != nil {
+			return
+		}
+		parsed[i] = c
+	}
+
+	leaf, err := x509.ParseCertificate(cert.Certificate[0])
+	if err != nil {
+		return
+	}
+
+	ordered := make([][]byte, 0, len(chain))
+	used := make([]bool, len(chain))
+	currentIssuer := leaf.RawIssuer
+
+	for len(ordered) < len(chain) {
+		found := false
+		for i, c := range parsed {
+			if !used[i] && bytes.Equal(c.RawSubject, currentIssuer) {
+				ordered = append(ordered, chain[i])
+				used[i] = true
+				currentIssuer = c.RawIssuer
+				found = true
+				break
+			}
+		}
+		if !found {
+			break
+		}
+	}
+
+	for i, der := range chain {
+		if !used[i] {
+			ordered = append(ordered, der)
+		}
+	}
+
+	copy(cert.Certificate[1:], ordered)
+}
